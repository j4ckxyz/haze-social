<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/post.css">
    <%- include ('fragments/global-head.ejs') %>
    <link rel="stylesheet" href="/css/auth.css">
    <title>admin · haze</title>
</head>
<body>

    <%- include('fragments/header.ejs') %>

    <div class="scroll-container">
        <main>
            <div class="admin-panel">
                <h2>invite codes</h2>

                <div class="invite-actions">
                    <button id="generate-invite-btn" onclick="generateInvite()">generate invite code</button>
                </div>

                <div id="new-code-display" class="new-code hidden">
                    <span>new invite code: </span>
                    <code id="new-code-value"></code>
                    <button class="copy-btn" onclick="copyCode()">copy code</button>
                    <button class="copy-link-btn" onclick="copyInviteLink()">copy link</button>
                </div>

                <table class="invite-table">
                    <tr>
                        <th>code</th>
                        <th>status</th>
                        <th>used by</th>
                        <th>created by</th>
                        <th>actions</th>
                    </tr>
                    <% for (let invite of invites) { %>
                        <tr class="<%= invite.used_by ? 'used' : 'unused' %>">
                            <td><code><%= invite.code %></code></td>
                            <td>
                                <% if (invite.used_by) { %>
                                    <span>used</span>
                                <% } else { %>
                                    <span class="unused-badge">available</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (invite.used_by_username && invite.used_by_path) { %>
                                    <a href="/posts/<%= invite.used_by_path %>">@<%= invite.used_by_username %></a>
                                <% } else { %>
                                    <span>-</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (invite.created_by_username && invite.created_by_path) { %>
                                    <a href="/posts/<%= invite.created_by_path %>">@<%= invite.created_by_username %></a>
                                <% } else { %>
                                    <i>system</i>
                                <% } %>
                            </td>
                            <td>
                                <% if (!invite.used_by) { %>
                                    <button type="button" class="inline-button-link" onclick="copyInviteLinkFor('<%= invite.code %>', this)">copy link</button>
                                <% } else { %>
                                    <span>-</span>
                                <% } %>
                            </td>
                        </tr>
                    <% } %>
                    <% if (invites.length === 0) { %>
                        <tr>
                            <td colspan="5"><i>no invite codes yet</i></td>
                        </tr>
                    <% } %>
                </table>
            </div>
        </main>
    </div>

</body>

<script>
    async function generateInvite() {
        const btn = document.getElementById('generate-invite-btn');
        btn.disabled = true;
        btn.textContent = 'generating...';

        try {
            const res = await fetch('/api/admin/generate-invite', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();

            if (data.code) {
                const display = document.getElementById('new-code-display');
                const value = document.getElementById('new-code-value');
                value.textContent = data.code;
                display.classList.remove('hidden');

                // reload after a moment so the table updates
                setTimeout(() => location.reload(), 1500);
            } else {
                alert(data.error || 'couldnt generate an invite code try again');
            }
        } catch (err) {
            alert('couldnt generate an invite code try again');
        }

        btn.disabled = false;
        btn.textContent = 'generate invite code';
    }

    function copyCode() {
        const code = document.getElementById('new-code-value').textContent;
        navigator.clipboard.writeText(code).then(() => {
            const btn = document.querySelector('.copy-btn');
            btn.textContent = 'copied';
            setTimeout(() => btn.textContent = 'copy code', 2000);
        });
    }

    function inviteUrlFromCode(code) {
        return `${window.location.origin}/signup?invite=${encodeURIComponent(code)}`;
    }

    function copyInviteLink() {
        const code = document.getElementById('new-code-value').textContent;
        const url = inviteUrlFromCode(code);
        navigator.clipboard.writeText(url).then(() => {
            const btn = document.querySelector('.copy-link-btn');
            btn.textContent = 'copied';
            setTimeout(() => btn.textContent = 'copy link', 2000);
        });
    }

    function copyInviteLinkFor(code, btn) {
        const url = inviteUrlFromCode(code);
        navigator.clipboard.writeText(url).then(() => {
            btn.textContent = 'copied';
            setTimeout(() => btn.textContent = 'copy link', 2000);
        });
    }
</script>

</html>
