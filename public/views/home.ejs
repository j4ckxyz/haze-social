<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/post.css">
    <%- include ('fragments/global-head.ejs') %>
    <title>haze</title>
</head>
<body>

    <%- include('fragments/header.ejs')  %>

    <div class="scroll-container">
        <main>
            <nav class="pager" aria-label="feed pages">
                <% if (page > 1) { %>
                    <a href="/page/<%= Number(page) - 1%>" aria-label="go to previous page">previous</a>
                <% } else { %>
                    <span class="pager-disabled">previous</span>
                <% } %>
                <small>page <%= page %></small>
                <% if (page < max_page) { %>
                    <a href="/page/<%= Number(page) + 1 %>" aria-label="go to next page">next</a>
                <% } else { %>
                    <span class="pager-disabled">next</span>
                <% } %>
            </nav>

            <% for (let post of feed) { %>
                <div class="post">
                    <table>
                        <tr>
                            <td>
                                <a href="/posts/<%= post.path %>" class="post-open-link" title="open post">open</a>
                            </td>
                            <td class="flex post-line">
                                <span class="grow">from <a href="/posts/<%= post.author_path %>"><em><%= post.author %></em></a> · <span class="date-relative"><%= post.timestamp %></span><% if (post.edited) { %> <a href="/history/<%= post.path %>" class="post-edited-link">(edited)</a><% } %></span>
                                <span class="post-actions">
                                    <% if (locals.user && locals.user.username === post.author) { %>
                                        <a href="/edit/<%= post.path %>">edit</a>
                                        <form action="/delete/<%= post.path %>" method="POST" class="inline-action" onsubmit="return confirm('delete this post?')"><button type="submit" class="inline-button-link">delete</button></form>
                                    <% } %>
                                    <a href="/reply/<%= post.path %>">reply</a>
                                </span>
                            </td>
                        </tr>
                        <% if (post.replying_to) { %>
                            <tr>
                                <td>reply:</td>
                                <td class="flex">
                                    <a class="grow" href="/posts/<%= post.replying_to.path %>">
                                        <%= post.replying_to.title %>
                                        <% if (post.replying_to.title == "[album]" || post.replying_to.title == "[image]" || post.replying_to.title == "[audio]") { %>
                                            · <span class="date-relative"><%= post.replying_to.timestamp %></span>
                                        <% } %>
                                    </a>
                                    <span>by <a href="/posts/<%= post.replying_to.author_path %>"><%= post.replying_to.author %></a></span>
                                </td>
                            </tr>
                        <% } %>
                    </table>
                    <% if (post.body != '') { %>
                        <div class="content">
                            <%- post.preview_body %>
                            <% if (post.preview_body != post.body) { %>
                                <p class="read-more"><a href="/posts/<%= post.path %>">read more...</a></p>
                            <% } %>
                        </div>
                    <% } %>
                    <table>
                        <% if (post.reply_count > 0) { %>
                            <tr>
                                <td>
                                    <a href="/posts/<%= post.path %>">
                                        <%= post.reply_count %>
                                        <% if (post.reply_count > 1) { %>
                                            replies
                                        <% } else { %> 
                                            reply
                                        <% } %>
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    </table>
                </div>
            <% } %>
    
            <% if (feed.length == 0) { %>
                <p><i>no posts yet — be the first to write one.</i></p>
            <% } %>
    
            <% if (page == max_page) { %>
                <p><i>you've reached the end for now.</i></p>
            <% } %>
        </main>

        <footer>
            <nav class="pager" aria-label="feed pages bottom">
                <% if (page > 1) { %>
                    <a href="/page/<%= Number(page) - 1%>">previous</a>
                <% } else { %>
                    <span class="pager-disabled">previous</span>
                <% } %>
                <span>page <%= page %></span>
                <% if (page < max_page) { %>
                    <a href="/page/<%= Number(page) + 1 %>">next</a>
                <% } else { %>
                    <span class="pager-disabled">next</span>
                <% } %>
            </nav>

            <div class="flex">
                <a id="subscription-anchor" class="hidden" tabindex="0">turn on notifications</a>
                <a id="app-install-anchor" tabindex="0" href="/how-to-install">install app</a>
                <span>v1.3</span>
            </div>
        </footer>
    </div>
    
</body>

<script src="/js/post.js"></script>
<script>
    treat_posts();

    //

    var install_prompt;
    var install_button = document.getElementById("app-install-anchor");
    
    window.addEventListener('beforeinstallprompt', e => {
        e.preventDefault();
        install_prompt = e;
        install_button.textContent = "install app";
        install_button.href = "#";
        install_button.onclick = install_app;
    });

    window.addEventListener('appinstalled', disable_install_prompt);

    async function install_app(event) {
        if (event) event.preventDefault();
        if (!install_prompt) return false;
        await install_prompt.prompt();
        disable_install_prompt();
        return false;
    }

    function disable_install_prompt() {
        install_button.textContent = "install app";
        install_button.href = "/how-to-install";
        install_button.onclick = null;
        install_prompt = null;
    }

    // enable push notifications

    var service_worker;

    window.addEventListener("load", async () => {
        service_worker = await navigator.serviceWorker.ready;
        if (service_worker) {
            var subscribe_button = document.getElementById("subscription-anchor");
            subscribe_button.onclick = subscribe;
            subscribe_button.classList.remove("hidden");
        }
    })

    async function subscribe() {
        if (!service_worker) return;
        let push = await service_worker.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: '<%= process.env.VAPID_PUBLIC_KEY %>'
        });

        localStorage.setItem("endpoint", push.endpoint);

        let form = new FormData();
        form.append("data", JSON.stringify(push));

        let result = await fetch('/subscribe', {
            method: 'POST',
            body: form
        })
        .then(res => res.json())
        .catch(err => console.log(err))

        if (result) {
            console.log(result);
        } else {
            alert("error subscribing to push notifications--try again later?");
        }
    }
</script>

</html>
