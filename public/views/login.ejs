<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/post.css">
    <%- include ('fragments/global-head.ejs') %>
    <link rel="stylesheet" href="/css/auth.css">
    <title>log in · haze</title>
</head>
<body>

    <%- include('fragments/header.ejs') %>

    <div class="scroll-container">
        <main>
            <div class="auth-form">
                <h2>log in</h2>
                <p class="auth-hint">welcome back — use the username and password you signed up with.</p>

                <% if (locals.error) { %>
                    <div class="auth-error"><%= error %></div>
                <% } %>

                <form method="POST" action="/login">
                    <div class="form-field">
                        <label for="login-username">username</label>
                        <input autofocus type="text" id="login-username" name="username" placeholder="your name" required
                            value="<%= locals.username || '' %>" autocomplete="username" autocapitalize="off">
                    </div>

                    <div class="form-field">
                        <label for="login-password">password</label>
                        <input type="password" id="login-password" name="password" placeholder="password" required autocomplete="current-password">
                        <div class="auth-hint"><small>if you forgot your password, ask your instance admin for help.</small></div>
                    </div>

                    <div class="form-field">
                        <button type="submit">log in</button>
                    </div>
                </form>

                <p class="auth-switch">
                    don't have an account? <a href="/signup">sign up</a>
                </p>
            </div>
        </main>
    </div>

</body>
</html>
