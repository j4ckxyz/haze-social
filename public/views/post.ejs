<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/css/post.css">
    <%- include ('fragments/global-head.ejs') %>
    <title><%= title %></title>
</head>
<body>

    <%- include('fragments/header.ejs') %>

    <div class="scroll-container">
        <main>
            <% if (timestamp != -1) { %>
                <% if (!locals.live || locals.live == false) { %>
                    <div class="post-not-live-banner">
                        <em>this post is being processed :)</em>
                        <span>the page will refresh once it's live.</span>
                    </div>
                <% } %>

                <div class="post">
                    <table>
                        <tr>
                            <td>
                                <a href="#" class="post-open-link" onclick="history.back(); return false;" aria-label="go back">
                                    back
                                </a>
                            </td>
                            <td class="flex post-line">
                                <span class="grow">from <a href="/posts/<%= author_path %>"><em><%= author %></em></a> · <span class="date-relative"><%= timestamp %></span><% if (locals.edited) { %> <a href="/history/<%= path %>" class="post-edited-link">(edited)</a><% } %></span>
                                <span class="post-actions">
                                    <% if (locals.user && locals.user.username === author) { %>
                                        <a href="/edit/<%= path %>">edit</a>
                                        <form action="/delete/<%= path %>" method="POST" class="inline-action" onsubmit="return confirm('delete this post?')"><button type="submit" class="inline-button-link">delete</button></form>
                                    <% } %>
                                    <a href="/reply/<%= path %>">reply</a>
                                </span>
                            </td>
                        </tr>
                        <% if (locals.replying_to) { %>
                            <tr>
                                <td>reply:</td>
                                <td class="flex">
                                    <a class="grow" href="/posts/<%= replying_to.path %>"><%= replying_to.title %></a>
                                    <span>by <a href="/posts/<%= replying_to.author_path %>"><%= replying_to.author %></a></span>
                                </td>
                            </tr>
                        <% } %>
                    </table>
                    <% if (body != '') { %>
                        <div class="content">
                            <%- body %>
                        </div>
                    <% } %>
                </div>

                <% if (locals.replies && replies.length > 0) { %>
                    <div><p class="section-label">replies</p></div>
                    <% for (let i=0; i<replies.length; i++) { %>
                        <% let post = replies[i] %>
                        <div class="post">
                            <table>
                                <tr>
                                    <td></td>
                                    <td class="flex post-line">
                                        <span class="grow">from <a href="/posts/<%= post.author_path %>"><em><%= post.author %></em></a> · <span class="date-relative"><%= post.timestamp %></span><% if (post.edited) { %> <a href="/history/<%= post.path %>" class="post-edited-link">(edited)</a><% } %></span>
                                        <span class="post-actions">
                                            <% if (locals.user && locals.user.username === post.author) { %>
                                                <a href="/edit/<%= post.path %>">edit</a>
                                                <form action="/delete/<%= post.path %>" method="POST" class="inline-action" onsubmit="return confirm('delete this post?')"><button type="submit" class="inline-button-link">delete</button></form>
                                            <% } %>
                                            <a href="/reply/<%= post.path %>">reply</a>
                                        </span>
                                    </td>
                                </tr>
                            </table>
                            <% if (post.body != '') { %>
                                <div class="content">
                                    <%- post.preview_body %>
                                    <% if (post.preview_body != post.body) { %>
                                        <p class="read-more"><a href="/posts/<%= post.path %>">read more...</a></p>
                                    <% } %>
                                </div>
                            <% } %>
                            <table>
                                <% if (post.reply_count > 0) { %>
                                    <tr>
                                        <td>
                                            <a href="/posts/<%= post.path %>">
                                                <%= post.reply_count %>
                                                <% if (post.reply_count > 1) { %>
                                                    replies
                                                <% } else { %> 
                                                    reply
                                                <% } %>
                                            </a>
                                        </td>
                                    </tr>
                                <% } %>
                            </table>
                        </div>
                    <% } %>
                <% } %>
            <% } else { %>
                <p>this post does not exist or is no longer available.</p>
                <p>
                    <a href="#" onclick="history.back(); return false;">go back</a>
                </p>
            <% } %>
        </main>
    </div>
    
</body>

<script src="/js/post.js"></script>
<script>
    treat_posts();

    // post is not live
    if (document.querySelector(".post-not-live-banner")) {
        check_live();
    }

    async function check_live() {
        var json = await fetch(window.location.href + '/is-live', {
            method: 'GET',
        })
        .then(res => res.json())
        .catch(err => console.log(err))

        if (json && (json.live || json.post_not_found)) {
            if (json.post_not_found) {
                alert("this post was purged due to an uploading error. sorry about that!");
                history.back();
            } else if (json.live) {
                window.location.reload();
            }
        } else {
            setTimeout(check_live, 1000);
        }
    }
</script>
</html>